# Copy this file to .env and fill in real values for local development.
# In production (Replit), set these as Secrets.

# ── Invite-only signup ────────────────────────────────────────────────────────
# Set INVITE_ENABLED=false to skip invite checks (future open signup).
# When true (default), new users must arrive via /api/login?invite=TOKEN.
INVITE_ENABLED=true

# Comma-separated list of valid invite tokens.
# Example: INVITE_TOKENS=alpha-abc123,beta-xyz789
# Leave empty to block all new signups (strict invite-only, no tokens distributed yet).
INVITE_TOKENS=

# ── Sentry error monitoring ───────────────────────────────────────────────────
# Backend DSN — set in Replit Secrets as SENTRY_DSN_BACKEND
SENTRY_DSN_BACKEND=

# Frontend DSN — exposed to the browser via Vite; set in Replit Secrets
VITE_SENTRY_DSN_FRONTEND=
